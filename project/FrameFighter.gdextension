[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true
hot_reload = true

[libraries]
linux.debug.x86_64 =     "res://../extension/target/debug/libframe_fighter.so"
linux.release.x86_64 =   "res://../extension/target/release/libframe_fighter.so"
windows.debug.x86_64 =   "res://../extension/target/debug/frame_fighter.dll"
windows.release.x86_64 = "res://../extension/target/release/frame_fighter.dll"
macos.debug =            "res://../extension/target/debug/libframe_fighter.dylib"
macos.release =          "res://../extension/target/release/libframe_fighter.dylib"
macos.debug.arm64 =      "res://../extension/target/debug/libframe_fighter.dylib"
macos.release.arm64 =    "res://../extension/target/release/libframe_fighter.dylib"

[icons]
FighterInput = "res://assets/fighter_input_node.png"
FighterActionMap = "res://assets/action_map_resource.png"
FighterMoveList = "res://assets/move_list_resource.png"
